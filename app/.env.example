# Supabase — Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — server-side only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct DB connection (for migrations and server-side queries)
DATABASE_URL=postgresql://postgres:YOURPASSWORD@db.your-project-ref.supabase.co:5432/postgres

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here
DEVIS_NOTIFY_EMAIL=you@example.com

# Airtable — Personal Access Token with data.records:write scope on the target base
AIRTABLE_API_KEY=pat_your-token-here
AIRTABLE_BASE_ID=app_your-base-id-here
AIRTABLE_DEVIS_TABLE=Devis

# Cookie consent — server-side pepper for hashing visitor IPs before storage (never store raw IP)
CONSENT_IP_PEPPER=generate-a-random-32-char-string

# Google Tag Manager — container ID (starts with GTM-)
# Only loads client-side after cookie-banner "accept" — see src/components/Analytics.tsx
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
